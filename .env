POSTGRES_URL=jdbc:postgresql://${POSTGRES_DB_HOST}:${POSTGRES_DB_PORT}/${POSTGRES_DB}

ALLOWED_ORIGINS=https://${IP_ADDRESS}:3000,http://${IP_ADDRESS}:3000,http://${IP_ADDRESS}:4200