IP_ADDRESS=192.168.0.103

SERVICE_PORT=8090

NOTES_SCHEMA=notes_schema

# Postgres settings
POSTGRES_DB_HOST=${IP_ADDRESS}
POSTGRES_DB_PORT=5432
POSTGRES_DB=notes_heimhel
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_URL=jdbc:postgresql://${POSTGRES_DB_HOST}:${POSTGRES_DB_PORT}/${POSTGRES_DB}

ALLOWED_ORIGINS=https://${IP_ADDRESS}:3000,http://${IP_ADDRESS}:3000,http://${IP_ADDRESS}:4200


KEYCLOAK_POSTGRES_USER=keycloak_postgres
KEYCLOAK_POSTGRES_PASSWORD=keycloak_postgres
KEYCLOAK_POSTGRES_DB=keycloak_db

KEYCLOAK_HTTP_PORT=8080
KEYCLOAK_DEBUG_PORT=8787
KEYCLOAK_HOSTNAME=http://${IP_ADDRESS}:8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin